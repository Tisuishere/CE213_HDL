module lab1_2c (SW,HEX0,HEX1,HEX2,HEX3,HEX4);
	input [17:15] SW;
	output [6:0]  HEX4, HEX3, HEX2, HEX1, HEX0;
	Mux_seg({3'b000, 3'b001, 3'b010, 3'b011, 3'b100}, SW[17:15], HEX4);
	Mux_seg({3'b001, 3'b010, 3'b011, 3'b100, 3'b000}, SW[17:15], HEX3);
	Mux_seg({3'b010, 3'b011, 3'b100, 3'b000, 3'b001}, SW[17:15], HEX2);
	Mux_seg({3'b011, 3'b100, 3'b000, 3'b001, 3'b010}, SW[17:15], HEX1);
	Mux_seg({3'b100, 3'b000, 3'b001, 3'b010, 3'b011}, SW[17:15], HEX0);
endmodule
